#!/bin/zsh
# era — mission architect for MAI.
# Turns a rough prompt into a well-structured MISSION.md + DONE.template.md
# in the target folder, then AUTO-STARTS `mai <folder>` to execute the mission.
# (mai can still be run separately at any time: mai <folder>)
#
# Usage:
#   era <folder> "<rough prompt>"
#   era . "make my api faster"
#
# Env overrides:
#   MODEL=haiku era ...          # model for drafting (inherited by mai too if set)
#   ERA_AUTO_MAI=0 era ...       # draft only, do NOT auto-start mai

set -u

SCRIPT_DIR="${0:A:h}"

TARGET_RAW="${1:?usage: era <folder> \"<rough prompt>\"}"
PROMPT="${2:?usage: era <folder> \"<rough prompt>\"}"
mkdir -p "$TARGET_RAW"
TARGET="${TARGET_RAW:A}"

MODEL="${MODEL:-sonnet}"

LOG_DIR="$TARGET/.agent/logs"
mkdir -p "$LOG_DIR"
RUN_ID="$(date +%Y%m%d-%H%M%S)"
LOG="$LOG_DIR/era-$RUN_ID.log"           # human-readable, same as console
RAW_LOG="$LOG_DIR/era-$RUN_ID.jsonl"     # full stream-json events (audit/debug)

# Live log formatter (stream-json -> readable lines). Falls back to cat.
LOGFMT="$SCRIPT_DIR/oda-logfmt"
if command -v python3 >/dev/null && [[ -f "$LOGFMT" ]]; then
  logfmt() { python3 -u "$LOGFMT"; }
else
  logfmt() { cat; }
fi

SYSTEM="You are ERA, a mission architect for an autonomous agent system called MAI. MAI agents run unattended: they get MISSION.md, work alone with full admin rights inside this folder (read-only outside), can spawn parallel subagents, and stop only when they write DONE.md proving the goal is achieved.

Your job, from the user's rough prompt:
1. Briefly inspect this folder (if not empty) to ground the mission in reality.
2. Write MISSION.md with sections: # Mission (one-line goal), ## Context (folder state, relevant facts), ## Tasks (concrete steps, mark which can run as parallel subagents), ## Constraints (what NOT to do), ## Verification (exact commands/checks proving success — must be objectively checkable), ## Deliverables (exact filenames the agent must produce).
3. Write DONE.template.md — the acceptance checklist the final DONE.md must satisfy: every deliverable listed, every verification step with its expected result, checkbox format.

Rules: make the end goal VERIFIABLE (commands, file existence, measurable thresholds) — never fuzzy words like 'improve' without a metric. Keep both files tight and unambiguous; an agent with zero access to the user must execute them without questions. Write ONLY these two files, change nothing else. Do not start executing the mission yourself."

cd "$TARGET" || exit 1

echo "[era] target  : $TARGET"
echo "[era] model   : $MODEL"
echo "[era] log     : $LOG"
echo "[era] drafting MISSION.md + DONE.template.md ..."

claude -p \
  --model "$MODEL" \
  --permission-mode acceptEdits \
  --allowedTools "Read,Write,Edit,Glob,Grep" \
  --append-system-prompt "$SYSTEM" \
  --verbose \
  --output-format stream-json \
  -- "Rough mission prompt from the user: $PROMPT" 2>>"$LOG" \
  | tee -a "$RAW_LOG" \
  | logfmt \
  | tee -a "$LOG"

if [[ ! -f "$TARGET/MISSION.md" ]]; then
  echo "[era] ⚠️  MISSION.md was not created — see output above" >&2
  exit 1
fi

if [[ "${ERA_AUTO_MAI:-1}" != "1" ]]; then
  echo ""
  echo "[era] ✅ ready (ERA_AUTO_MAI=0). Review MISSION.md, then launch:"
  echo "      mai $TARGET"
  exit 0
fi

# Hand off to MAI for the same mission. Prefer the mai next to this script
# (works for repo checkout and ~/.local/bin symlinks alike), fall back to PATH.
MAI_BIN="$SCRIPT_DIR/mai"
[[ -x "$MAI_BIN" ]] || MAI_BIN="$(command -v mai || true)"
if [[ -z "$MAI_BIN" ]]; then
  echo "[era] ⚠️  mai not found — MISSION.md is ready, launch manually:" >&2
  echo "      mai $TARGET" >&2
  exit 1
fi

echo ""
echo "[era] ✅ MISSION.md ready — auto-starting MAI for this mission"
echo "[era] handing off: $MAI_BIN $TARGET"
exec "$MAI_BIN" "$TARGET"
