#!/usr/bin/env python3
"""oda-logfmt — turn Claude Code stream-json output into readable live log lines.

Reads stream-json events on stdin, prints one human line per event:
  [HH:MM:SS] >> session start
  [HH:MM:SS] AI  <assistant text>
  [HH:MM:SS] TOOL Bash: npm test
  [HH:MM:SS]   ok <result preview>
  [HH:MM:SS] == run end: success | 12 turns | 95s | $0.42
Non-JSON lines pass through untouched.
"""
import json
import sys
import datetime

MAX_PREVIEW = 160


def ts():
    return datetime.datetime.now().strftime("%H:%M:%S")


def clip(text):
    text = " ".join(str(text).split())
    if len(text) > MAX_PREVIEW:
        return text[: MAX_PREVIEW - 3] + "..."
    return text


def emit(line):
    print(line, flush=True)


def tool_detail(inp):
    if not isinstance(inp, dict):
        return ""
    for key in ("description", "command", "file_path", "pattern", "url",
                "prompt", "query", "skill"):
        if inp.get(key):
            return clip(inp[key])
    return clip(inp) if inp else ""


def handle(ev):
    t = ev.get("type")
    if t == "system" and ev.get("subtype") == "init":
        emit(f"[{ts()}] >> session start | model: {ev.get('model', '?')} "
             f"| cwd: {ev.get('cwd', '?')}")
    elif t == "assistant":
        for block in ev.get("message", {}).get("content", []):
            btype = block.get("type")
            if btype == "text" and block.get("text", "").strip():
                for line in block["text"].strip().splitlines():
                    emit(f"[{ts()}] AI  {line}")
            elif btype == "tool_use":
                emit(f"[{ts()}] TOOL {block.get('name', '?')}: "
                     f"{tool_detail(block.get('input'))}")
    elif t == "user":
        content = ev.get("message", {}).get("content", [])
        if not isinstance(content, list):
            return
        for block in content:
            if not isinstance(block, dict) or block.get("type") != "tool_result":
                continue
            body = block.get("content")
            if isinstance(body, list):
                body = " ".join(b.get("text", "") for b in body
                                if isinstance(b, dict))
            mark = "ERR" if block.get("is_error") else "ok"
            emit(f"[{ts()}]   {mark} {clip(body or '')}")
    elif t == "result":
        parts = [f"run end: {ev.get('subtype', '?')}"]
        if ev.get("num_turns") is not None:
            parts.append(f"{ev['num_turns']} turns")
        if ev.get("duration_ms") is not None:
            parts.append(f"{ev['duration_ms'] / 1000:.0f}s")
        if ev.get("total_cost_usd") is not None:
            parts.append(f"${ev['total_cost_usd']:.4f}")
        emit(f"[{ts()}] == " + " | ".join(parts))
        if ev.get("result") and ev.get("subtype") != "success":
            emit(f"[{ts()}]    {clip(ev['result'])}")


def main():
    for raw in sys.stdin:
        raw = raw.strip()
        if not raw:
            continue
        try:
            ev = json.loads(raw)
        except ValueError:
            emit(raw)
            continue
        try:
            handle(ev)
        except Exception:
            emit(raw)


if __name__ == "__main__":
    main()
